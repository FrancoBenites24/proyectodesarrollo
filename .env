# ── Camera ──────────────────────────────────────
CAMERA_SOURCE=0

# ── Detection thresholds ─────────────────────────
EAR_THRESHOLD=0.25
MOR_THRESHOLD=0.6
PERCLOS_WINDOW_SECONDS=3
PERCLOS_FPS=30

# ── Logging ──────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/drowsyguard.log

# ── Alerts ───────────────────────────────────────
# URL opcional para recibir alertas via webhook
ALARM_WEBHOOK_URL=
ALARM_COOLDOWN_SECONDS=5

# ── API ──────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://drowsyguard:drowsyguard123@127.0.0.1:5433/drowsyguard
POSTGRES_USER=drowsyguard
POSTGRES_PASSWORD=drowsyguard123
POSTGRES_DB=drowsyguard

# Alert mode: "voice" para alertas habladas, "tone" para tonos
ALERT_MODE=voice
